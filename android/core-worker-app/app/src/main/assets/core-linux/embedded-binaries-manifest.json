{
  "schema": "core-worker-embedded-binaries-manifest-v2",
  "stage": "core-linux-embedded-binaries-build-pipeline-v1",
  "abi": "arm64-v8a",
  "androidMinSdk": 26,
  "policy": {
    "noRuntimeDownload": true,
    "noPlaceholder": true,
    "noBedrockBundledInApk": true,
    "noExecutionDuringBuild": true,
    "allowOnlyNativeLibraryDirForFutureExecution": true
  },
  "targets": {
    "runner": {
      "officialName": "libcoreworker_runner.so",
      "source": "android/core-worker-app/app/src/main/cpp/coreworker_runner.c",
      "origin": "local-core-worker-safe-preflight-runner"
    },
    "proot": {
      "officialName": "libcoreworker_proot.so",
      "origin": "manual-build-or-audited-import",
      "upstream": "https://github.com/proot-me/proot"
    },
    "busybox": {
      "officialName": "libcoreworker_busybox.so",
      "origin": "manual-build-from-upstream-source",
      "upstream": "https://busybox.net/downloads/"
    },
    "box64": {
      "officialName": "libcoreworker_box64.so",
      "origin": "manual-build-from-upstream-source",
      "upstream": "https://github.com/ptitSeb/box64"
    }
  }
}
