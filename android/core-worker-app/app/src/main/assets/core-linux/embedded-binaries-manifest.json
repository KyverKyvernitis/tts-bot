{
  "schema": "core-worker-embedded-binaries-intake-v1",
  "stage": "core-linux-embedded-binaries-intake-v1",
  "abi": "arm64-v8a",
  "policy": {
    "noAutoDownload": true,
    "noRuntimeExecution": true,
    "noRemoteArbitraryCommand": true,
    "onlyNativeLibraryDirMayBecomeExecutable": true,
    "rejectWritableAppHomeExecutables": true
  },
  "expected": {
    "executor": ["libcoreworker_executor.so"],
    "runner": ["libcoreworker_runner.so"],
    "proot": ["libcoreworker_proot.so", "libproot.so"],
    "busybox": ["libcoreworker_busybox.so", "libbusybox.so"],
    "box64": ["libcoreworker_box64.so", "libbox64.so"]
  },
  "notes": [
    "Este manifesto não contém binários reais.",
    "O APK só deve marcar um componente como pronto quando o arquivo ELF arm64 real existir em jniLibs/arm64-v8a.",
    "Bedrock server não entra no APK; será preparado por import controlado em etapa futura."
  ]
}
