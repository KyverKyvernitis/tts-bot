# Copie para ~/.phone-lavalink.env no celular e ajuste sem commitar segredo.
PHONE_LAVALINK_PASSWORD=troque-esta-senha
PHONE_LAVALINK_PORT=2333
PHONE_LAVALINK_PROOT_DISTRO=debian
PHONE_LAVALINK_HOST_DIR=$HOME/lavalink
PHONE_LAVALINK_PROOT_DIR=/root/lavalink
PHONE_LAVALINK_JAVA_XMX=768m
PHONE_LAVALINK_TMUX_SESSION=lavalink-debian
PHONE_LAVALINK_WATCH_INTERVAL_SECONDS=60

# O phone-worker turbo pode iniciar o Lavalink automaticamente quando a música precisar.
PHONE_LAVALINK_AUTO_START=true
PHONE_LAVALINK_AUTO_START_COOLDOWN_SECONDS=30
