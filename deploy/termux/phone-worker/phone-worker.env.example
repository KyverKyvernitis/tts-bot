# Copie para ~/.phone-worker.env no Termux.
# Use uma chave aleatória. Não envie esse token no chat.
PHONE_WORKER_TOKEN=troque_essa_chave
PHONE_WORKER_HOST=0.0.0.0
PHONE_WORKER_PORT=8766
PHONE_WORKER_DIR=/data/data/com.termux/files/home/phone-worker
PHONE_WORKER_TMUX_SESSION=phone-worker
PHONE_WORKER_START_WAIT_SECONDS=3
PHONE_WORKER_WATCH_INTERVAL_SECONDS=60
# Patch 41: manter 60 para tentar de novo a cada minuto mesmo após falha.
PHONE_WORKER_BOOT_DELAY_SECONDS=25
PHONE_WORKER_PID_FILE=/data/data/com.termux/files/home/phone-worker/phone-worker.pid
PHONE_WORKER_STATUS_FILE=/data/data/com.termux/files/home/phone-worker/phone-worker.status
PHONE_WORKER_LOCK_DIR=/data/data/com.termux/files/home/phone-worker/.phone-worker-start.lock
PHONE_WORKER_LOG_FILE=/data/data/com.termux/files/home/phone-worker/phone-worker.log
PHONE_WORKER_LOG_MAX_BYTES=1048576
PHONE_WORKER_WATCH_LOG_FILE=/data/data/com.termux/files/home/phone-worker/phone-worker-watch.log
PHONE_WORKER_WATCH_LOCK_DIR=/data/data/com.termux/files/home/phone-worker/.phone-worker-watch.lock
PHONE_WORKER_WATCH_PID_FILE=/data/data/com.termux/files/home/phone-worker/phone-worker-watch.pid
PHONE_WORKER_WATCH_MAX_BACKOFF_SECONDS=60
PHONE_WORKER_START_KILL_DUPLICATES=true
PHONE_WORKER_MAX_BODY_MB=32
PHONE_WORKER_MAX_OUTPUT_MB=32
PHONE_WORKER_JOB_TIMEOUT_SECONDS=45
PHONE_WORKER_HTTP_LOGS=false
# Diagnóstico do canal de wake via SSH usado pela VPS.
# O SSH precisa estar ativo no Termux para o botão "Acordar phone-worker" funcionar remotamente.
# A VPS também precisa ter PHONE_WORKER_SSH_USER/PHONE_WORKER_SSH_PORT no .env dela.
PHONE_WORKER_SSH_PORT=8022
# Patch 47: watchdog tenta subir sshd automaticamente se ele existir e estiver parado.
PHONE_WORKER_SSHD_AUTO_START=true

# Core Worker registry/heartbeat da VPS.
# Depois de gerar o código no painel workers, rode:
#   ~/phone-worker/pair-phone-worker.sh CORE-XXXX http://IP_TAILSCALE_DA_VPS:10000 "Meu Worker" midia
#   # ou tudo de uma vez:
#   ~/phone-worker/bootstrap-phone-worker.sh CORE-XXXX http://IP_TAILSCALE_DA_VPS:10000 "Meu Worker" midia
# O script preenche CORE_WORKER_ID/TOKEN automaticamente.
# Não envie esse token para GitHub nem para chat público.
CORE_WORKER_HEARTBEAT_ENABLED=false
CORE_WORKER_VPS_URL=http://100.x.x.x:10000
CORE_WORKER_ID=phone-redmi-01
CORE_WORKER_TOKEN=preenchido_pelo_pair_phone_worker
CORE_WORKER_NAME=Redmi Worker 01
CORE_WORKER_PROFILE=midia
CORE_WORKER_ROLES=phone-worker,diagnostics,log-summary,zip-validate,ffmpeg,ffprobe,tts-convert,vps-assist
CORE_WORKER_CAPABILITIES=phone-worker,diagnostics,log-summary,zip-validate,ffmpeg,ffprobe,tts-convert,vps-assist,hash-worker,endpoint-probe,media-probe,audio-convert,worker-logs,network-probe,tailscale-status
# Para um celular builder dedicado, use:
# CORE_WORKER_PROFILE=builder
# CORE_WORKER_ROLES=phone-worker,diagnostics,log-summary,maintenance-plan,apk-builder,zip-validate,vps-assist,cache-worker
# CORE_WORKER_CAPABILITIES=phone-worker,diagnostics,log-summary,maintenance-plan,apk-builder,zip-validate,vps-assist,cache-worker,hash-worker,endpoint-probe,media-probe,worker-logs,network-probe,tailscale-status,boot-repair,service-control
CORE_WORKER_HEARTBEAT_INTERVAL_SECONDS=30
CORE_WORKER_JOBS_ENABLED=true
CORE_WORKER_JOB_POLL_INTERVAL_SECONDS=10
CORE_WORKER_JOB_RESULT_MAX_BYTES=262144
CORE_WORKER_LOG_LINES=140

# Self-update seguro: permite o job worker_update aplicar apenas arquivos whitelisted
# do phone-worker e reiniciar depois de responder à VPS. Não mexe no .env local.
PHONE_WORKER_SELF_UPDATE_ENABLED=true
PHONE_WORKER_UPDATE_RESTART=true
PHONE_WORKER_UPDATE_MAX_FILE_BYTES=524288
PHONE_WORKER_UPDATE_MAX_TOTAL_BYTES=1048576
PHONE_WORKER_PENDING_RESULTS_FILE=/data/data/com.termux/files/home/phone-worker/phone-worker-pending-results.json
PHONE_WORKER_UPDATE_STATUS_FILE=/data/data/com.termux/files/home/phone-worker/phone-worker-update.status.json

# Builder de APK opcional.
# Use apenas em celular forte marcado com perfil/função builder/apk-builder.
# A VPS prepara um source zip leve e o worker compila/publica o APK.
PHONE_WORKER_APK_BUILD_ENABLED=true
PHONE_WORKER_APK_BUILD_DIR=/data/data/com.termux/files/home/core-worker-apk-builds
PHONE_WORKER_APK_BUILD_TIMEOUT_SECONDS=3600
PHONE_WORKER_APK_BUILD_SOURCE_MAX_BYTES=230686720
PHONE_WORKER_APK_PUBLISH_TIMEOUT_SECONDS=60
# Opcional: URL que a VPS deve usar para falar com este celular.
# CORE_WORKER_ENDPOINT=http://100.x.x.x:8766

# Serviços whitelisted controlados por jobs seguros:
# - phone-worker: status/start/restart/stop do agente atual
# - phone-worker-watch: start/stop/restart/status do watchdog local em tmux
# - tailscale: diagnóstico apenas; start/stop do app oficial Tailscale fica no Android
PHONE_WORKER_WATCH_TMUX_SESSION=phone-worker-watch

# Permite jobs auxiliares seguros para aliviar a VPS quando este celular estiver online.
CORE_WORKER_ASSIST_ENABLED=true

# Perfil forte para celular confiável/carregando:
# CORE_WORKER_PROFILE=turbo
# CORE_WORKER_ROLES=phone-worker,diagnostics,log-summary,maintenance-plan,zip-validate,ffmpeg,ffprobe,tts-convert,tts-synth,tts-benchmark,tts-piper,tts-agent,apk-builder,vps-assist,cache-worker
# CORE_WORKER_CAPABILITIES=phone-worker,diagnostics,log-summary,maintenance-plan,zip-validate,ffmpeg,ffprobe,tts-convert,tts-synth,tts-benchmark,tts-piper,tts-agent,apk-builder,vps-assist,cache-worker,hash-worker,endpoint-probe,media-probe,audio-convert,worker-logs,network-probe,tailscale-status,service-control,boot-repair


# Piper experimental do perfil turbo. Não coloque modelo pesado no GitHub; salve localmente no celular.
# PHONE_WORKER_PIPER_COMMAND=piper
# PHONE_WORKER_PIPER_MODEL=/data/data/com.termux/files/home/piper-models/pt_BR/model.onnx
# PHONE_WORKER_PIPER_CONFIG=/data/data/com.termux/files/home/piper-models/pt_BR/model.onnx.json
# PHONE_WORKER_PIPER_MODEL_NAME=turbo-default
# PHONE_WORKER_PIPER_EXTRA_ARGS=
# PHONE_WORKER_PIPER_MP3_BITRATE=96k
# PHONE_WORKER_PIPER_CACHE_ENABLED=true
# PHONE_WORKER_PIPER_CACHE_DIR=/data/data/com.termux/files/home/phone-worker/cache/piper
# PHONE_WORKER_PIPER_CACHE_MAX_MB=2048
# PHONE_WORKER_PIPER_CACHE_MAX_FILES=4096

# Auto-dependências do perfil turbo. Padrão seguro: instala somente o que estiver faltando,
# com timeout/cooldown e sem builds nativos por padrão. Valores antigos off/manual agora
# funcionam como safe-only; use disabled/never se quiser bloquear qualquer auto-install.
PHONE_WORKER_DEPS_INSTALL_MODE=safe
PHONE_WORKER_TURBO_DEPS_INSTALL_MODE=safe
# PHONE_WORKER_TURBO_DEPS_INSTALL=auto
# Modo seguro real é explícito e impede Music Agent/voz automáticos.
# PHONE_WORKER_SAFE_MODE=false
# Dependências pesadas opcionais, como Google Cloud TTS/grpcio, só instalam com opt-in explícito.
# Mesmo com opt-in, pip usa --only-binary por padrão para não compilar com clang.
# PHONE_WORKER_HEAVY_PYTHON_DEPS_INSTALL=false
# PHONE_WORKER_ALLOW_PIP_SOURCE_BUILDS=false
# Google Cloud TTS nativo no worker turbo usa pacotes Termux antes do pip:
# pkg install python-grpcio python-cryptography protobuf libprotobuf
# depois pip install google-cloud-texttospeech. Não compile grpcio/cryptography no celular.
# Encerra builds pesados opcionais que ficaram presos por patch antigo quando heavy deps estão desativadas.
# PHONE_WORKER_KILL_STALE_HEAVY_DEP_BUILDS=true
# PHONE_WORKER_DEPS_INSTALL_COOLDOWN_SECONDS=900
# PHONE_WORKER_DEPS_INSTALL_TIMEOUT_SECONDS=240
# PHONE_WORKER_PIPER_MODEL_AUTO_DOWNLOAD=true
# PHONE_WORKER_PIPER_DEB_URL=
# PHONE_WORKER_PIPER_MODEL_URL=https://huggingface.co/rhasspy/piper-voices/resolve/main/pt/pt_BR/edresson/low/pt_BR-edresson-low.onnx?download=true
# PHONE_WORKER_PIPER_CONFIG_URL=https://huggingface.co/rhasspy/piper-voices/resolve/main/pt/pt_BR/edresson/low/pt_BR-edresson-low.onnx.json?download=true

# Auto-instala dependências de TTS/voz faltantes no worker sem travar o heartbeat.
# Não tenta compilar Google Cloud TTS/grpcio por padrão.
# PHONE_WORKER_AUTO_INSTALL_TTS_DEPS=true
# PHONE_WORKER_AUTO_INSTALL_TTS_DEPS_COOLDOWN_SECONDS=900
# PHONE_WORKER_AUTO_INSTALL_TTS_DEPS_TIMEOUT_SECONDS=420

# TTS Agent: rota normal quando a VPS detectar este worker turbo online/saudável.
# O bot troca de modo por health cacheado; não fica testando o worker a cada frase.
PHONE_WORKER_TTS_AGENT_ENABLED=true
PHONE_WORKER_TTS_AGENT_ENGINE=auto
PHONE_WORKER_TTS_AGENT_CONCURRENCY=1
PHONE_WORKER_TTS_AGENT_TIMEOUT_SECONDS=10
PHONE_WORKER_TTS_AGENT_MAX_TEXT_LENGTH=1200
# Google Cloud no worker turbo confiável. A chave fica somente em runtime/secrets, nunca no patch/GitHub.
PHONE_WORKER_TTS_AGENT_GCLOUD_ENABLED=true
PHONE_WORKER_GOOGLE_TTS_ENABLED=true
PHONE_WORKER_GOOGLE_APPLICATION_CREDENTIALS=/data/data/com.termux/files/home/phone-worker/secrets/google-tts-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=/data/data/com.termux/files/home/phone-worker/secrets/google-tts-service-account.json
PHONE_WORKER_GOOGLE_TTS_AUDIO_ENCODING=OGG_OPUS
PHONE_WORKER_GOOGLE_TTS_LANGUAGE=pt-BR
PHONE_WORKER_GOOGLE_TTS_VOICE=pt-BR-Standard-A

# Worker Voice Agent: base compartilhada para Music + TTS no plano de voz do worker.
# A VPS continua como cérebro/controle; quando saudável, o worker pode tocar TTS direto no Discord voice.
PHONE_WORKER_VOICE_AGENT_ENABLED=true
PHONE_WORKER_VOICE_AGENT_SHARED_SESSION_ENABLED=true
PHONE_WORKER_VOICE_AGENT_DIRECT_TTS_ENABLED=true
PHONE_WORKER_VOICE_AGENT_DIRECT_TTS_AUTO_ENABLED=true
PHONE_WORKER_VOICE_AGENT_DIRECT_TTS_MAX_CHARS=600
PHONE_WORKER_VOICE_AGENT_DIRECT_TTS_TIMEOUT_SECONDS=30
PHONE_WORKER_VOICE_AGENT_DIRECT_MUSIC_ENABLED=true
PHONE_WORKER_VOICE_AGENT_SESSION_TTL_SECONDS=180
PHONE_WORKER_VOICE_AGENT_HANDOFF_ENABLED=true
PHONE_WORKER_VOICE_AGENT_HANDOFF_TTL_SECONDS=60
PHONE_WORKER_VOICE_AGENT_TRANSFER_CONTROL_ENABLED=true
PHONE_WORKER_VOICE_AGENT_TRANSFER_LEASE_TTL_SECONDS=45
PHONE_WORKER_VOICE_AGENT_CONNECTION_DRY_RUN_ENABLED=true
PHONE_WORKER_VOICE_AGENT_CONNECTION_AUTO_PROBE_ENABLED=false
PHONE_WORKER_VOICE_AGENT_CONNECTION_TIMEOUT_SECONDS=4
# O Music Agent aceita áudio prebuilt OGG/Opus enviado pela VPS para TTS direto.
# A VPS controla GOOGLE_CLOUD_TTS_AUDIO_ENCODING=OGG_OPUS; aqui só limitamos o payload recebido.
MUSIC_AGENT_TTS_MAX_B64_BYTES=8388608
# Estado local das sessões registradas pela VPS. Não guarda DISCORD_TOKEN nem voice token bruto.
# O handoff real de voz fica somente em memória e expira rápido.
# PHONE_WORKER_VOICE_AGENT_STATE_FILE=/data/data/com.termux/files/home/phone-worker/voice-agent-state.json

# Cache TTS genérico do worker turbo usado como segunda camada da VPS.
# PHONE_WORKER_TTS_CACHE_DIR=/data/data/com.termux/files/home/phone-worker/cache/tts
# PHONE_WORKER_TTS_CACHE_MAX_MB=4096
# PHONE_WORKER_TTS_CACHE_MAX_FILES=20000

# Ajustes equivalentes no ambiente da VPS para evitar consultas repetidas ao worker por cache miss/erro.
# TTS_TURBO_WORKER_CACHE_MISS_COOLDOWN_SECONDS=45
# TTS_TURBO_WORKER_CACHE_ERROR_COOLDOWN_SECONDS=10
# TTS_TURBO_WORKER_CACHE_INDEX_MAX_ENTRIES=4096

# Repara automaticamente Termux:Boot e o autostart de shell quando o worker detectar boot incompleto.
# O autostart de shell faz o watchdog subir silenciosamente ao abrir o Termux.
PHONE_WORKER_AUTO_BOOT_REPAIR=true

# Música worker-only: yt-dlp roda no phone worker, não na VPS.
# O arquivo é segredo local do celular; não commitar/enviar para GitHub.
PHONE_WORKER_MUSIC_YTDLP_COOKIES_FILE=/data/data/com.termux/files/home/phone-worker/secrets/youtube-cookies.txt
PHONE_WORKER_MUSIC_YTDLP_JS_RUNTIMES=node
PHONE_WORKER_MUSIC_YTDLP_DEFAULT_SEARCH=ytsearch
# Busca textual usa metadata leve para mostrar 5 opções; stream real só depois da seleção.
MUSIC_WORKER_YTDLP_SEARCH_TIMEOUT_SECONDS=12
# Opcional: fallback para baixar componentes EJS se o pacote yt-dlp-ejs não estiver instalado.
# PHONE_WORKER_MUSIC_YTDLP_REMOTE_COMPONENTS=ejs:github

# Música worker-local/PCM: legado. A rota normal agora é Music Agent direto no worker.
# Mantenha apenas para diagnóstico/compatibilidade; a VPS não deve usar isso como caminho normal.
PHONE_WORKER_MUSIC_STREAM_MODE=prepared
PHONE_WORKER_MUSIC_PCM_CACHE_DIR=/data/data/com.termux/files/home/phone-worker/cache/music-pcm
PHONE_WORKER_MUSIC_PCM_CACHE_MAX_MB=2048
PHONE_WORKER_MUSIC_PREPARE_TIMEOUT_SECONDS=0
PHONE_WORKER_MUSIC_PREPARE_MAX_DURATION_SECONDS=1800
PHONE_WORKER_MUSIC_PREPARE_LIVE_FALLBACK=false
# Buffer da VPS ao ler PCM preparado do celular.
MUSIC_WORKER_STREAM_CONNECT_TIMEOUT_SECONDS=90
MUSIC_WORKER_STREAM_READY_TIMEOUT_SECONDS=90
MUSIC_WORKER_STREAM_PREBUFFER_SECONDS=8.0
MUSIC_WORKER_STREAM_MAX_BUFFER_SECONDS=30.0
MUSIC_WORKER_STREAM_UNDERRUN_LOG_EVERY=25

# Music Agent: modo padrão da música. Mesmo bot no phone worker para controlar voz/música.
# O token do bot fica apenas local no worker, nunca no Git.
MUSIC_AGENT_ENABLED=true
# auto respeita o modo seguro; use true só quando quiser forçar o backend musical no celular.
PHONE_WORKER_START_MUSIC_AGENT=auto
# Auto-install do Music Agent só instala dependências leves por padrão.
# Google Cloud TTS/grpcio é opcional e só instala com opt-in explícito para evitar compilação pesada no celular.
MUSIC_AGENT_DEPS_INSTALL_MODE=safe
# MUSIC_AGENT_HEAVY_PYTHON_DEPS_INSTALL=false
# MUSIC_AGENT_ALLOW_PIP_SOURCE_BUILDS=false
# MUSIC_AGENT_AUTO_INSTALL_TERMUX_PACKAGES=true
# MUSIC_AGENT_DEPS_INSTALL_COOLDOWN_SECONDS=900
# MUSIC_AGENT_DEPS_INSTALL_TIMEOUT_SECONDS=240
MUSIC_AGENT_HOST=127.0.0.1
MUSIC_AGENT_PORT=8780
MUSIC_AGENT_TOKEN=
# Token do mesmo bot, guardado só no phone worker. Não commitar.
MUSIC_AGENT_BOT_TOKEN=
MUSIC_AGENT_YTDLP_COOKIES_FILE=$HOME/phone-worker/secrets/youtube-cookies.txt
MUSIC_AGENT_YTDLP_JS_RUNTIMES=node
MUSIC_AGENT_YTDLP_DEFAULT_SEARCH=ytsearch1
MUSIC_AGENT_YTDLP_TIMEOUT_SECONDS=35
# Caminho padrão: Music Agent/discord.py direto no worker.
# Lavalink/NodeLink não fazem mais parte do worker.
MUSIC_AGENT_DIRECT_AUDIO_ENABLED=true
MUSIC_AGENT_DIRECT_YOUTUBE_ENABLED=true
MUSIC_AGENT_PREPARING_TIMEOUT_SECONDS=30
# Fim normal de fila fica em AFK/idle antes de sair da call; não desconecta instantaneamente.
MUSIC_AGENT_IDLE_DISCONNECT_SECONDS=120
MUSIC_AGENT_DIRECT_CONFIRM_SECONDS=0.35
# Cache/prefetch reduzem a espera quando o usuário escolhe um resultado logo depois da busca.
# Metadata pode ficar por horas; URL tocável do YouTube expira e fica em cache curto.
MUSIC_AGENT_METADATA_CACHE_TTL_SECONDS=21600
MUSIC_AGENT_STREAM_CACHE_TTL_SECONDS=180
MUSIC_AGENT_RESOLVE_CACHE_TTL_SECONDS=300
MUSIC_AGENT_PREFETCH_ENABLED=true
MUSIC_AGENT_PREFETCH_TOP_RESULTS=2
MUSIC_AGENT_PREFETCH_TIMEOUT_SECONDS=18
MUSIC_AGENT_PREFETCH_BEFORE_END_SECONDS=45
MUSIC_AGENT_STATUS_POLL_SECONDS=0.75
MUSIC_WORKER_SEARCH_CACHE_TTL_SECONDS=420
MUSIC_WORKER_DIRECT_CACHE_TTL_SECONDS=90
MUSIC_AGENT_FFMPEG_OPUS_BITRATE_KBPS=128
