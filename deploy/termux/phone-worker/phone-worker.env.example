# Copie para ~/.phone-worker.env no Termux.
# Use uma chave aleatória. Não envie esse token no chat.
PHONE_WORKER_TOKEN=troque_essa_chave
PHONE_WORKER_HOST=0.0.0.0
PHONE_WORKER_PORT=8766
PHONE_WORKER_DIR=/data/data/com.termux/files/home/phone-worker
PHONE_WORKER_TMUX_SESSION=phone-worker
PHONE_WORKER_START_WAIT_SECONDS=3
PHONE_WORKER_WATCH_INTERVAL_SECONDS=60
PHONE_WORKER_MAX_BODY_MB=32
PHONE_WORKER_MAX_OUTPUT_MB=32
PHONE_WORKER_JOB_TIMEOUT_SECONDS=45
PHONE_WORKER_HTTP_LOGS=false

# Core Worker registry/heartbeat da VPS.
# Depois de usar /workers > Parear APK, salve aqui o worker_id e o token retornados.
# Não envie esse token para GitHub nem para chat público.
CORE_WORKER_HEARTBEAT_ENABLED=false
CORE_WORKER_VPS_URL=http://100.x.x.x:8000
CORE_WORKER_ID=phone-redmi-01
CORE_WORKER_TOKEN=cole_o_token_do_pareamento_aqui
CORE_WORKER_NAME=Redmi Worker 01
CORE_WORKER_ROLES=phone-worker,diagnostics,log-summary,zip-validate,ffmpeg,ffprobe,tts-convert
CORE_WORKER_CAPABILITIES=phone-worker,diagnostics,log-summary,maintenance-plan,zip-validate,ffmpeg,ffprobe,tts-convert,worker-logs,network-probe,tailscale-status,service-control
CORE_WORKER_HEARTBEAT_INTERVAL_SECONDS=30
CORE_WORKER_JOBS_ENABLED=true
CORE_WORKER_JOB_POLL_INTERVAL_SECONDS=10
CORE_WORKER_JOB_RESULT_MAX_BYTES=262144
CORE_WORKER_LOG_LINES=140
# Opcional: URL que a VPS deve usar para falar com este celular.
# CORE_WORKER_ENDPOINT=http://100.x.x.x:8766

# Serviços whitelisted controlados por jobs seguros:
# - phone-worker: status/start/restart/stop do agente atual
# - phone-worker-watch: start/stop/restart/status do watchdog local em tmux
# - tailscale: diagnóstico apenas; start/stop do app oficial Tailscale fica no Android
PHONE_WORKER_WATCH_TMUX_SESSION=phone-worker-watch
