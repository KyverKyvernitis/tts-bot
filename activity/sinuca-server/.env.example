# Osaka Dashboard — backend web
NODE_ENV=production
PORT=8787

# Aplicação Discord usada pelo OAuth2 e pelo convite do bot
DISCORD_CLIENT_ID=seu_client_id_aqui
DISCORD_CLIENT_SECRET=seu_client_secret_aqui
DISCORD_BOT_TOKEN=token_do_bot_aqui
DASHBOARD_BOT_INVITE_PERMISSIONS=8

# O callback cadastrado no Discord deve ser:
# https://osakaagiota.duckdns.org/api/auth/callback
DASHBOARD_PUBLIC_URL=https://osakaagiota.duckdns.org
DASHBOARD_ALLOWED_ORIGINS=https://osakaagiota.duckdns.org

# Gere um segredo aleatório forte e estável. Trocar esse valor encerra todas as sessões.
DASHBOARD_SESSION_SECRET=troque-por-um-segredo-aleatorio-com-pelo-menos-32-caracteres
DASHBOARD_SESSION_COLLECTION=dashboard_sessions

# Mesma base usada pelo bot
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=chat_revive
MONGODB_COLLECTION=settings
