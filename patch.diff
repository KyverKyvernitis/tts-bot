+    wanted_fp = str(source_fingerprint or source_sha256 or "").strip()
+    workdirs = sorted([p for p in build_root.glob("build-*") if p.is_dir()], key=lambda path: path.stat().st_mtime if path.exists() else 0, reverse=True)
