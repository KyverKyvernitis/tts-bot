+// Box64 é ELF Linux/glibc executável, não shared library Android/Bionic.
+// Por isso fica em assets, não em jniLibs, para evitar que AGP/strip/mergeNativeLibs
+// trate o arquivo como lib Android. Esta verificação não executa Box64.
+def coreLinuxBox64Asset = [key: "box64", file: "core-linux/bin/box64", minBytes: 131072L, required: false]
+
+tasks.register("verifyCoreLinuxBox64Asset") {
+    description = "Valida o Box64 controlado em assets sem executar o binário."
+    doLast {
+        def f = file("${projectDir}/src/main/assets/${coreLinuxBox64Asset.file}")
+        if (!f.exists()) {
+            println("Core Linux Box64 asset v14.2.1: ausente; preflight deve reportar missing_binary")
+            return
+        }
+        byte[] head = new byte[Math.min(64, Math.max(0, f.length() as int))]
+        if (head.length > 0) {
+            f.withInputStream { it.read(head) }
+        }
+        def isElf = head.length >= 4 && head[0] == 0x7f && (head[1] & 0xff) == 69 && (head[2] & 0xff) == 76 && (head[3] & 0xff) == 70
+        def is64 = head.length >= 5 && head[4] == 2
+        def isAarch64 = head.length >= 20 && (head[18] & 0xff) == 183 && (head[19] & 0xff) == 0
+        def tooSmall = f.length() < (coreLinuxBox64Asset.minBytes as long)
+        def reasons = []
+        if (!isElf) reasons << "not_elf"
+        if (isElf && !is64) reasons << "not_elf64"
+        if (isElf && !isAarch64) reasons << "not_aarch64"
+        if (tooSmall) reasons << "size ${f.length()} < ${coreLinuxBox64Asset.minBytes}"
+        if (!reasons.isEmpty()) {
+            throw new GradleException("Core Linux Box64 asset inválido: ${reasons.join('; ')}")
+        }
+        println("Core Linux Box64 asset v14.2.1: present=true size=${f.length()} path=${coreLinuxBox64Asset.file}; execução bloqueada até V15")
+    }
+}
+
+
 tasks.named("preBuild").configure {
     dependsOn("verifyCoreLinuxEmbeddedBinaries")
+    dependsOn("verifyCoreLinuxBox64Asset")
 }
 
 
