# Core Worker PC Linux
# Copie para ~/.core-worker.env e ajuste antes de parear.

CORE_WORKER_VPS_URL=https://sua-vps:10000
CORE_WORKER_NAME=Meu-PC
CORE_WORKER_PROFILE=turbo
CORE_WORKER_SOURCE=linux-pc-worker
CORE_WORKER_DEVICE_TYPE=linux_pc
CORE_WORKER_RUNTIME_MODE=linux-pc
CORE_WORKER_HOST=127.0.0.1
CORE_WORKER_PORT=8766

# Preenchidos automaticamente após parear:
CORE_WORKER_ID=
CORE_WORKER_TOKEN=

# Música/TTS pelo worker turbo. Nunca commite tokens/segredos.
DISCORD_TOKEN=
MUSIC_AGENT_ENABLED=auto
MUSIC_AGENT_DIRECT_AUDIO_ENABLED=true
MUSIC_AGENT_YTDLP_COOKIES_FILE=$HOME/core-worker/secrets/youtube-cookies.txt
PHONE_WORKER_TTS_AGENT_ENABLED=auto
PHONE_WORKER_TTS_AGENT_ENGINE_ORDER=edge,gtts,google

# Compatibilidade com scripts herdados.
PHONE_WORKER_ENV=$HOME/.core-worker.env
PHONE_WORKER_DIR=$HOME/core-worker
PHONE_WORKER_HOST=127.0.0.1
PHONE_WORKER_PORT=8766
